ssh-aws() {
    if [ $# -eq 0 ]; then
        echo "Usage: ssh-aws <hostname> (e.g., ip-172-31-84-165)"
        return 1
    fi
    local hostname="$1.ec2.internal"
    aws ec2-instance-connect ssh --os-user ubuntu --instance-id $(aws ec2 describe-instances --filters "Name=private-dns-name,Values=$hostname" --query "Reservations[*].Instances[*].InstanceId" --output text)
}
killport() {
  if [ -z "$1" ]; then
    echo "Usage: killport <port>"
    return 1
  fi
  # find the process IDs using the given port, then kill them
  PIDS=$(lsof -t -i:"$1" 2>/dev/null)
  if [ -n "$PIDS" ]; then
    sudo kill -9 $PIDS
    echo "Killed processes on port $1: $PIDS"
  else
    echo "No process found on port $1"
  fi
}
