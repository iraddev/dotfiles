# Produce to a topic interactively
kproduce() {
  if [ -z "$1" ]; then
    echo "Usage: kproduce <topic>"
    return 1
  fi
  local topic="$1"
  shift
  local extra_args="$*"
  local pod_name="kafka-producer-$$"
  
  # Set up trap to delete pod on interrupt
  trap "kubectl delete pod -n novee $pod_name --ignore-not-found=true >/dev/null 2>&1" INT TERM
  
  kubectl run -n novee "$pod_name" --image=quay.io/strimzi/kafka:0.48.0-kafka-4.1.0 --restart=Never -it --rm --overrides='{
      "spec": {
        "containers": [{
          "name": "kafka-producer",
          "image": "quay.io/strimzi/kafka:0.48.0-kafka-4.1.0",
          "command": ["sh", "-c"],
          "args": ["/opt/kafka/bin/kafka-console-producer.sh --bootstrap-server \"$BOOTSTRAP_SERVERS\" --producer.config <(cat <<EOF\nsasl.jaas.config=org.apache.kafka.common.security.scram.ScramLoginModule required username=\"$USERNAME\" password=\"$PASSWORD\";\nsecurity.protocol=$SECURITY_PROTOCOL\nsasl.mechanism=$SASL_MECHANISM\nEOF\n) --topic '"$topic"' '"$extra_args"'"],
          "stdin": true,
          "tty": true,
          "securityContext": {
            "runAsUser": 0,
            "runAsGroup": 0,
            "allowPrivilegeEscalation": true
          },
          "envFrom": [{
            "secretRef": {
              "name": "novee-kafka-access-novee"
            }
          }],
          "env": [
            {"name": "BOOTSTRAP_SERVERS", "valueFrom": {"secretKeyRef": {"name": "novee-kafka-access-novee", "key": "bootstrap.servers"}}},
            {"name": "USERNAME", "valueFrom": {"secretKeyRef": {"name": "novee-kafka-access-novee", "key": "username"}}},
            {"name": "PASSWORD", "valueFrom": {"secretKeyRef": {"name": "novee-kafka-access-novee", "key": "password"}}},
            {"name": "SECURITY_PROTOCOL", "valueFrom": {"secretKeyRef": {"name": "novee-kafka-access-novee", "key": "securityProtocol"}}},
            {"name": "SASL_MECHANISM", "valueFrom": {"secretKeyRef": {"name": "novee-kafka-access-novee", "key": "saslMechanism"}}}
          ]
        }],
        "restartPolicy": "Never"
      }
    }'
  
  # Clean up trap
  trap - INT TERM
}

# Consume from a topic (tails new messages)
kconsume() {
  if [ -z "$1" ]; then
    echo "Usage: kconsume <topic> [additional-params...]"
    return 1
  fi
  local topic="$1"
  shift
  local extra_args="$*"
  kubectl run -n novee kafka-consumer --image=quay.io/strimzi/kafka:0.48.0-kafka-4.1.0 --restart=Never -i --rm --overrides='{
      "spec": {
        "containers": [{
          "name": "kafka-consumer",
          "image": "quay.io/strimzi/kafka:0.48.0-kafka-4.1.0",
          "command": ["sh", "-c"],
          "args": ["/opt/kafka/bin/kafka-console-consumer.sh --bootstrap-server \"$BOOTSTRAP_SERVERS\" --consumer.config <(cat <<EOF\nsasl.jaas.config=org.apache.kafka.common.security.scram.ScramLoginModule required username=\"$USERNAME\" password=\"$PASSWORD\";\nsecurity.protocol=$SECURITY_PROTOCOL\nsasl.mechanism=$SASL_MECHANISM\nEOF\n) --topic '"$topic"' '"$extra_args"'"],
          "stdin": true,
          "tty": false,
          "securityContext": {
            "runAsUser": 0,
            "runAsGroup": 0,
            "allowPrivilegeEscalation": true
          },
          "envFrom": [{
            "secretRef": {
              "name": "novee-kafka-access-novee"
            }
          }],
          "env": [
            {"name": "BOOTSTRAP_SERVERS", "valueFrom": {"secretKeyRef": {"name": "novee-kafka-access-novee", "key": "bootstrap.servers"}}},
            {"name": "USERNAME", "valueFrom": {"secretKeyRef": {"name": "novee-kafka-access-novee", "key": "username"}}},
            {"name": "PASSWORD", "valueFrom": {"secretKeyRef": {"name": "novee-kafka-access-novee", "key": "password"}}},
            {"name": "SECURITY_PROTOCOL", "valueFrom": {"secretKeyRef": {"name": "novee-kafka-access-novee", "key": "securityProtocol"}}},
            {"name": "SASL_MECHANISM", "valueFrom": {"secretKeyRef": {"name": "novee-kafka-access-novee", "key": "saslMechanism"}}}
          ]
        }],
        "restartPolicy": "Never"
      }
    }'
  
  # Clean up trap
  trap - INT TERM
}

kpsql() {
  if [ -z "$1" ]; then
    echo "Usage: kpsql <query>"
    return 1
  fi
  
  # Wrap query in json_agg for JSON output
  local query="$1"
  local json_query="SELECT json_agg(t) FROM ($query) t;"
  
  kubectl run -n novee psql-query --image=postgres:16-alpine --restart=Never -i --rm --quiet=false --overrides='
  {
    "spec": {
      "containers": [{
        "name": "psql-query",
        "image": "postgres:16-alpine",
        "stdin": true,
        "tty": false,
        "command": ["sh", "-c", "exec psql --host=\"$DATABASE_HOST\" --port=\"$DATABASE_PORT\" --username=\"$DATABASE_USERNAME\" --dbname=novee --set=sslmode=require --pset=pager=off -t -A -c \"'"$json_query"'\""],
        "env": [
          {
            "name": "PGPASSWORD",
            "valueFrom": {
              "secretKeyRef": {
                "name": "rds",
                "key": "DATABASE_PASSWORD"
              }
            }
          }
        ],
        "envFrom": [{
          "secretRef": {
            "name": "rds"
          }
        }]
      }],
      "restartPolicy": "Never"
    }
  }' 2>/dev/null
}
